{
  "name": "__APP_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun dist/server.js",
    "build": "bun build src/server.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck",
    "format": "bun run tools/format.ts --write",
    "format:check": "bun run tools/format.ts --check",
    "verify": "bun ci && bun run format:check && bun run lint && bun test && bun run build",
    "verify:ci": "bun run format:check && bun run lint && bun test && bun run build"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@canary"
}
