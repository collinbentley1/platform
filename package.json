{
  "name": "@collinbentley/platform",
  "version": "0.1.2",
  "description": "Reusable Bun, GitOps, and Google Cloud Run platform for Collin Bentley projects.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "bin": {
    "platform": "./tools/platform.ts"
  },
  "scripts": {
    "platform": "bun run tools/platform.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bun run tools/lint.ts",
    "format": "bun run tools/format.ts --write",
    "format:check": "bun run tools/format.ts --check",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@canary"
}
